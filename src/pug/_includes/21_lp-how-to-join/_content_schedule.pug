      { start: '19:30', end: '20:15' },
      { start: '20:30', end: '21:15' }
    ],
    days: [
      { name: '月', type: 'single', classes: [null, null, null, null] },
      { 
        name: '火', 
        type: 'single',
        classes: [
          [{ subject: '哲学', level: 2, class: 'philosophy' }],
          [{ subject: '哲学', level: 1, class: 'philosophy' }],
