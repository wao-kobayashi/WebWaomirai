//- 条件付きリンクを生成するmixin
//- loycus変数の値によって、通常のリンク or LIFFフォームへのリンクを切り替える
//- @param {string} baseClass - リンクに適用する基本CSSクラス名
mixin conditionalLink(baseClass)
  a(
    class=baseClass + (loycus ? '' : ' js-line-trigger')
    href=loycus ? UrlLiffForm : false
    target=loycus ? '_blank' : false
  )
    block

//- 固定フッターボタンのmixin
//- ページ下部に固定表示される申込ボタンとページトップへ戻るボタン
mixin fixed-btn
  .fixed-btn-container(style='display:none;')
    +conditionalLink('fixed-cta')
      |LINEで簡単申込(無料)
    a.btn-pagetop(href="#")
      i.fas.fa-arrow-up


//- CTA（Call To Action）ボタンのmixin
//- メインの申込ボタンとして使用
mixin btn-cta 
  +conditionalLink('btn-cta')
    img(src=ImgbtnCta)

mixin btn-cta-big
  +conditionalLink('btn-cta')
    img(src=ImgbtnCtaBig)

//- モーダルウィンドウのmixin
//- 2種類のモーダルとオーバーレイ背景を含む
mixin modal
  .modal#modal-alreadyfriend(style='display:none;')
    .modal-wrapper 
      .modal-wrapper-close
          .modal-wrapper-close-icon.modal-close
      .modal-wrapper-content   
         .modal-wrapper-content-title-alreadyfriend
            .modal-wrapper-content-title-alreadyfriend-top
                div|すでに
                div 
                  img(src=ImgIcnWaoLine)
                div|ワオ未来塾公式LINEを
            .modal-wrapper-content-title-alreadyfriend-bottom
                |友だち追加している方へ
         .modal-wrapper-content-main

            .modal-wrapper-content-main-text-alreadyfriend
              |イベントの申し込み案内が
              br
              |自動で届かない場合がございます。
              br
              |その場合は下記手順で申込ください。
            .modal-wrapper-content-main-image-alreadyfriend
              img(src=ImgModalEvent)
            .modal-wrapper-content-main-btn-alreadyfriend
                a(href=UrlLiffAddFriend, target='_blank')
                  |OKです(イベント申込へ)
  .modal#modal-pc-liff(style='display:none;')
    .modal-wrapper 
      .modal-wrapper-content
         .modal-wrapper-content-main
            .modal-wrapper-content-main-head
              .modal-wrapper-content-main-head-img
                img(src='https://waomirai.com/lp/assets/lpimages/07_event-lp-2025feb/icon_howto_join01.png')
              .modal-wrapper-content-main-head-text 
                 |スマホで
                 br
                 |LINEの友だち追加
            .modal-wrapper-content-main-qr#liffqr
              
            .modal-wrapper-content-main-text
                        |追加後に申込フォームが
                        br
                        |送信されます
         .modal-wrapper-content-close.modal-close 
                |閉じる
  .bg-modal(style='display:none;')