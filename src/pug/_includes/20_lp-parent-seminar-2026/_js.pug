script.
  $(document).ready(function() { 
    //loycusかどうか判定
    var loycus = '#{loycus}'

    $('.inview-triger').on('inview', function(event, isInView) {
      if (isInView) {
        $(this).addClass('inview');
      }
    });
    $(window).on("load scroll", function () {
       if ($(this).scrollTop() > 600) {
        $(".fixed-btn-container").fadeIn();

      } else {
        $(".fixed-btn-container").fadeOut();
  
      }
    });

    /**
    * モーダルウィンドウを開く関数
    * モーダルと背景を表示する
    */
    function modalPcLiffOpen() {
      $('#modal-pc-liff, .bg-modal').show();
    }
    function ModalAlreadyFriendOpen() {
      $('#modal-alreadyfriend, .bg-modal').show();
    }

    /**
    * ボタン動作の更新関数
    * 画面幅に応じてボタンの動作を切り替える
    * PC: モーダルを開く動作
    * スマホ: 通常のリンク動作
    */

    function updateButtonBehavior() {
      // 769px以上をPC表示とみなす
      var isWideScreen = $(window).width() >= 769;
      //loycusではない時に発火
      if (!loycus) {
        // locyus=false の時：js-line-trigger が有効
        $('.js-line-trigger').off('click').on('click', function(e) {
          if (isWideScreen) {
            e.preventDefault(); // PC：リンク無効化してモーダルを開く
            modalPcLiffOpen();
          }
          // スマホ：preventDefault() しないので href へそのまま遷移
        });
      }
    }

  /**
  * 画面サイズ変更対応
  * ページ読み込み時とリサイズ時にボタン動作を更新する
  * これによりPC/スマホの表示切替時に適切な動作になる
  */
  $(window).on('load resize', updateButtonBehavior);

    
    /**
    * モーダルを閉じる処理
    * 閉じるボタンまたは背景クリック時にモーダルを非表示にする
    */
    $('.modal-close, .bg-modal').click(function() {
      $('.modal-vimeo, .modal, .bg-modal').hide();
    });
   new QRCode(document.getElementById("liffqr"), "#{UrlLiffAddFriend}");
  });



script.
  $(document).ready(function () {
    // スクロール連動ナビゲーション
      // -----------------------------
      
      /**
      * スクロール位置に応じてナビゲーションのアクティブ状態を更新する関数
      */
      function updateSeminarNavigation() {
        const scrollTop = $(window).scrollTop();
        const navItems = $('.seminar-blocks-sticky-links li');
        const offset = 50; // アクティブ判定のオフセット(px)
        
        let activeId = null;
        
        // 講師紹介セクションをチェック
        const teacherSection = $('#teacher');
        if (teacherSection.length > 0) {
          const teacherTop = teacherSection.offset().top;
          const teacherBottom = teacherTop + teacherSection.outerHeight();
          
          if (scrollTop >= teacherTop - offset && scrollTop < teacherBottom) {
            activeId = 'teacher';
          }
        }
        
        // セミナーセクションをチェック(講師紹介でアクティブが決まっていない場合)
        if (!activeId) {
          const sections = $('.seminar-blocks-content-subject');
          sections.each(function() {
            const $section = $(this);
            const sectionTop = $section.offset().top;
            const sectionBottom = sectionTop + $section.outerHeight();
            
            // スクロール位置がセクションの上端から50px以内に入っているか判定
            if (scrollTop >= sectionTop - offset && scrollTop < sectionBottom) {
              activeId = $section.attr('id');
              return false; // 最初に見つかったセクションで処理を中断
            }
          });
        }
        
        // 全てのliからactiveクラスを削除
        navItems.removeClass('active');
        
        // 該当するliにactiveクラスを追加
        if (activeId) {
          navItems.find(`a[href="#${activeId}"]`).parent('li').addClass('active');
        }
      }
      
      // スクロールイベントにリスナーを設定(パフォーマンス最適化のためrequestAnimationFrameを使用)
      let ticking = false;
      
      $(window).on('scroll', function() {
        if (!ticking) {
          window.requestAnimationFrame(function() {
            updateSeminarNavigation();
            ticking = false;
          });
          ticking = true;
        }
      });
      
      // 初回実行
      updateSeminarNavigation();
      

    });